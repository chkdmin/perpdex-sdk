{
  "name": "@chkdmin/perpdex-sdk",
  "version": "0.3.4",
  "description": "Unified SDK for fetching positions and balances from perpetual DEXes",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src/signers/*.dylib",
    "src/signers/*.so",
    "src/signers/*.dll"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "ccxt": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "ccxt": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "ccxt": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chkdmin/perpdex-sdk"
  },
  "license": "MIT",
  "dependencies": {
    "@noble/ed25519": "^3.0.0",
    "koffi": "^2.15.1"
  }
}
